  "tweets": [
    {
      "id": "2052550313559609738",
      "text": "SMB life without a big IT team means AI tools often create more chaos than calm. \n\nWe get the integration headaches. \n\nHere's the fix. \n\nConnect email, CRM, and accounting like one smooth highway so data flows automatically and rarely breaks when tools change.",
      "author_id": "1286152332204359680",
      "username": "intellinovus",
      "name": "Intellinovus",
      "created_at": "2026-05-08T00:45:03.000Z",
      "conversation_id": "2052550313559609738",
      "metrics": {
        "likes": 0,
        "retweets": 0,
        "replies": 0,
        "quotes": 0,
        "impressions": 0,
