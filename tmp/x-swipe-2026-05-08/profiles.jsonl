    },
    {
      "id": "2050334732815090008",
      "text": "Does @harvey  still have a Lexis connection? Trying to use it through my school account, but I can't seem to find it.",
      "author_id": "2843928804",
      "username": "ordonez_adan",
      "name": "Adan Ordonez",
